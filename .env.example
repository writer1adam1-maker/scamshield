# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRO_PRICE_ID=

# App
NEXT_PUBLIC_APP_URL=

# Admin (server-only — never expose via NEXT_PUBLIC_)
# Comma-separated list of admin email addresses
ADMIN_EMAILS=

# Email (Resend)
RESEND_API_KEY=
RESEND_FROM=noreply@scamshieldy.com

# Google OAuth (for Gmail Shield)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Gmail Shield encryption
GMAIL_ENCRYPTION_KEY=
GMAIL_REDIRECT_URI=

# Vercel Cron secret (sent as Bearer token in Authorization header)
CRON_SECRET=

# Paddle billing
PADDLE_API_KEY=
PADDLE_WEBHOOK_SECRET=
PADDLE_PRICE_ID=
PADDLE_ENVIRONMENT=sandbox
